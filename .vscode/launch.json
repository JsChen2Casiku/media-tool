{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "media-tool: FastAPI Web",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app:app",
        "--host",
        "127.0.0.1",
        "--port",
        "8051",
        "--reload"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}\\.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "MEDIA_TOOL_STORAGE_ROOT": "${workspaceFolder}\\runtime\\storage",
        "MEDIA_TOOL_LOG_ROOT": "${workspaceFolder}\\runtime\\logs"
      }
    },
    {
      "name": "media-tool: CLI Extract Demo",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}\\cli.py",
      "args": [
        "extract",
        "-t",
        "https://www.douyin.com/video/7396822576074460467",
        "--transcription-base-url",
        "http://127.0.0.1:9000",
        "--transcription-language",
        "zh"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}\\.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "MEDIA_TOOL_STORAGE_ROOT": "${workspaceFolder}\\runtime\\storage",
        "MEDIA_TOOL_LOG_ROOT": "${workspaceFolder}\\runtime\\logs"
      }
    },
    {
      "name": "media-tool: MCP Server",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}\\mcp_server.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "envFile": "${workspaceFolder}\\.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}",
        "MEDIA_TOOL_STORAGE_ROOT": "${workspaceFolder}\\runtime\\storage",
        "MEDIA_TOOL_LOG_ROOT": "${workspaceFolder}\\runtime\\logs"
      }
    }
  ]
}
