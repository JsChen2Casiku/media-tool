# ======================================
# media-tool 环境变量示例
# 所有文件请使用 UTF-8 编码保存
# ======================================

# ------------------------------
# Python / 构建源配置
# ------------------------------

# pip 默认索引地址。网络较慢时可替换为镜像源。
MEDIA_TOOL_PIP_INDEX_URL=https://pypi.org/simple

# 额外 pip 索引地址。通常留空，只有在私有源或补充源时再填写。
MEDIA_TOOL_PIP_EXTRA_INDEX_URL=


# ------------------------------
# 基础运行配置
# ------------------------------

# 运行目录根路径。默认会在项目根目录下创建 runtime。
MEDIA_TOOL_RUNTIME_ROOT=

# 数据存储目录。留空时默认使用 runtime\storage。
MEDIA_TOOL_STORAGE_ROOT=

# 日志目录。留空时默认使用 runtime\logs。
MEDIA_TOOL_LOG_ROOT=

# 本地运行时可显式指定 ffmpeg 可执行文件完整路径；Docker 内通常不需要填写。
MEDIA_TOOL_FFMPEG_PATH=

# 常规 HTTP 请求超时时间，单位秒。
MEDIA_TOOL_REQUEST_TIMEOUT=30

# 媒体源文件下载失败时的自动重试次数。
MEDIA_TOOL_DOWNLOAD_RETRY_ATTEMPTS=3

# 后台异步任务工作线程数。
MEDIA_TOOL_JOB_WORKERS=2

# 单个任务最多保留多少条执行日志。
MEDIA_TOOL_JOB_MAX_LOGS=120

# 项目内部缓存上限，单位 MB。
MAX_CACHE_SIZE_MB=15

# 仅在需要生成本地静态地址的场景下使用，通常可留空。
DOMAIN=


# ------------------------------
# 登录认证配置
# ------------------------------

# 登录页面默认账号。
MEDIA_TOOL_AUTH_USERNAME=admin

# 登录页面默认密码。首次部署后建议立即修改。
MEDIA_TOOL_AUTH_PASSWORD=admin123

# 是否仅在 HTTPS 下发送登录 Cookie。
# 如果前面有 Nginx / Caddy / Traefik 等 HTTPS 反向代理，建议改为 true。
MEDIA_TOOL_AUTH_COOKIE_SECURE=false

# 登录会话有效期，单位秒。默认 7 天。
MEDIA_TOOL_AUTH_SESSION_TTL=604800

# 认证配置持久化文件路径。通常留空，使用默认路径 runtime/storage/auth.env 即可。
MEDIA_TOOL_AUTH_CONFIG_PATH=


# ------------------------------
# Whisper ASR 转写配置
# ------------------------------

# Whisper ASR 服务地址。
# Docker Compose 内通常使用 http://whisper-asr:9000
# Windows 本地调试通常使用 http://127.0.0.1:9000
MEDIA_TOOL_TRANSCRIPTION_BASE_URL=http://whisper-asr:9000

# 转写任务类型：
# transcribe = 原语言转写
# translate  = 翻译为英文
MEDIA_TOOL_TRANSCRIPTION_TASK=transcribe

# 默认语言代码，例如 zh、en。留空时由 ASR 自动检测。
MEDIA_TOOL_TRANSCRIPTION_LANGUAGE=zh

# 单次转写超时时间，单位秒。
MEDIA_TOOL_TRANSCRIPTION_TIMEOUT=300

# 是否在转写前由 Whisper 服务执行重编码。
MEDIA_TOOL_TRANSCRIPTION_ENCODE=true

# 是否返回逐词时间戳。
MEDIA_TOOL_TRANSCRIPTION_WORD_TIMESTAMPS=false

# 是否启用静音过滤。
MEDIA_TOOL_TRANSCRIPTION_VAD_FILTER=false

# Whisper 容器运行引擎。
MEDIA_TOOL_ASR_ENGINE=faster_whisper

# Whisper 模型大小。
# 可选值通常包括 tiny、base、small、medium、large
MEDIA_TOOL_ASR_MODEL=small

# Whisper 运行设备。无 GPU 时使用 cpu，有 CUDA 时可改为 cuda。
MEDIA_TOOL_ASR_DEVICE=cpu


# ------------------------------
# LLM 文案校正配置
# ------------------------------

# OpenAI 兼容接口地址，用于对 ASR 转写结果做错别字和语义连贯性校正。
MEDIA_TOOL_LLM_API_BASE=https://api.openai.com/v1

# OpenAI 兼容接口密钥。留空则跳过 LLM 文案校正。
MEDIA_TOOL_LLM_API_KEY=

# 默认校正模型名称。
MEDIA_TOOL_LLM_MODEL=gpt-5.4

# LLM 校正超时时间，单位秒。
MEDIA_TOOL_LLM_TIMEOUT=90
